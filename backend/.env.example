# ─── Server ─────────────────────────────────────────────────────────
PORT=8787
# Comma-separated list of allowed origins (your Vercel URL + local dev)
FRONTEND_ORIGIN=http://localhost:5173

# ─── Supabase (server secrets — NEVER expose to the browser) ────────
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── Brevo (transactional email API) ────────────────────────────────
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=DYCI Document Management System

# Public URL of the frontend (used in email links)
APP_URL=http://localhost:5173
